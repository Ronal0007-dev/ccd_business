extends ../layout

block content
  .page-header
    h1.page-title 📍 Business Locations
    a.btn.btn-outline(href="/dashboard") ← Dashboard

  if error && error.length
    .alert.alert-error ⚠️ #{error[0]}
  if success && success.length
    .alert.alert-success ✓ #{success[0]}

  .section-card
    .section-card-header
      h2 ➕ Add New Location
    .section-card-body
      form.inline-form(action="/locations" method="POST")
        .form-row
          .form-group
            label Location Name *
            input(type="text" name="locationName" placeholder="e.g. Kariakoo Market" required)
          .form-group
            label Ward *
            input(type="text" name="ward" placeholder="e.g. Kariakoo Ward" required)
          .form-group.form-action
            button.btn.btn-primary(type="submit") ➕ Add Location

  h2.section-title All Locations (#{locations.length})

  if locations.length === 0
    .empty-state
      .empty-icon 📍
      p No locations registered yet. Add one above.
  else
    .locations-list
      each loc in locations
        .location-full-card
          .location-full-header
            .lf-left
              .location-icon 📍
              .location-info
                h3.location-name= loc.locationName
                .location-ward 🏘️ #{loc.ward}
            .lf-right
              .lf-stats
                span.lf-stat
                  strong= loc.businessmen ? loc.businessmen.length : 0
                  |  Businessmen
                span.lf-stat
                  strong= loc.blocks ? loc.blocks.length : 0
                  |  Blocks/Zones
              form(action="/locations/" + loc.id + "?_method=DELETE" method="POST"
                onsubmit="return confirm('Delete this location and all its blocks/businessmen?')")
                input(type="hidden" name="_method" value="DELETE")
                button.btn.btn-danger.btn-sm(type="submit") 🗑 Delete Location

          .location-full-body
            //- Blocks section
            .blocks-section
              .blocks-header
                h4.blocks-title 🔲 Blocks / Zones
                button.btn.btn-sm.btn-outline.btn-add-block(
                  type="button"
                  data-loc=loc.id
                  onclick="toggleAddBlock(this)") ➕ Add Block/Zone

              //- Blocks list
              if loc.blocks && loc.blocks.length > 0
                .blocks-grid
                  each blk in loc.blocks
                    .block-chip
                      span.block-chip-name= blk.blockName
                      form.inline-form-del(
                        action="/locations/" + loc.id + "/blocks/" + blk.id + "?_method=DELETE"
                        method="POST"
                        onsubmit="return confirm('Delete block \"' + '#{blk.blockName}' + '\"?')")
                        input(type="hidden" name="_method" value="DELETE")
                        button.block-chip-del(type="submit" title="Delete block") ✕
              else
                p.no-blocks-yet No blocks/zones added yet.

              //- Add block inline form (hidden by default)
              .add-block-form(id="add-block-form-" + loc.id style="display:none")
                form.inline-form(action="/locations/" + loc.id + "/blocks" method="POST")
                  .form-row
                    .form-group
                      input(type="text" name="blockName" placeholder="e.g. Block A, Zone 1, Section North" required)
                    .form-group.form-action
                      button.btn.btn-primary.btn-sm(type="submit") ✓ Save
                      button.btn.btn-outline.btn-sm(type="button" onclick="toggleAddBlock(document.querySelector('[data-loc=\"#{loc.id}\"]'))") Cancel

block scripts
  script.
    function toggleAddBlock(btn) {
      const locId = btn.getAttribute('data-loc');
      const form = document.getElementById('add-block-form-' + locId);
      const isVisible = form.style.display !== 'none';
      form.style.display = isVisible ? 'none' : 'block';
      btn.textContent = isVisible ? '➕ Add Block/Zone' : '✕ Cancel';
      if (!isVisible) form.querySelector('input[name="blockName"]').focus();
    }
