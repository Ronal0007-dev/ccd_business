extends ../layout

block content
  .page-header
    h1.page-title 📥 CSV Import — Businessmen
    a.btn.btn-outline(href="/dashboard") ← Dashboard

  if error && error.length
    .alert.alert-error ⚠️ #{error[0]}

  //- Result panel
  if result
    .import-result(class= result.inserted > 0 ? 'result-success' : 'result-warn')
      .result-header
        .result-icon= result.inserted > 0 ? '✅' : '⚠️'
        .result-title Import Complete
      .result-stats
        .result-stat
          .rs-num= result.total
          .rs-lbl Total Rows
        .result-stat.rs-green
          .rs-num= result.inserted
          .rs-lbl Inserted
        .result-stat.rs-red
          .rs-num= result.skipped
          .rs-lbl Skipped
        .result-stat.rs-warn
          .rs-num= result.warnings.length
          .rs-lbl Warnings
      if result.errors && result.errors.length
        .result-section
          h4.result-section-title ❌ Errors / Skipped (#{result.errors.length})
          .result-list
            each e in result.errors.slice(0, 200)
              .result-list-item.item-error= e
          if result.errors.length > 200
            p.result-truncated-note Showing first 200 of #{result.errors.length} errors. Fix the issues above, re-export, and re-upload.
      if result.warnings && result.warnings.length
        .result-section
          h4.result-section-title ⚠️ Warnings (#{result.warnings.length})
          .result-list
            each w in result.warnings.slice(0, 200)
              .result-list-item.item-warn= w
          if result.warnings.length > 200
            p.result-truncated-note Showing first 200 of #{result.warnings.length} warnings.
      if result.inserted > 0
        .result-actions
          a.btn.btn-primary(href="/businessmen") 📋 View All Businessmen

  //- Upload form
  .section-card
    .section-card-header
      h2 Upload CSV File
      p.card-subtitle Maximum #{5000} rows per file · Only .csv files accepted · Max 10 MB
    .section-card-body
      form#importForm(action="/import" method="POST" enctype="multipart/form-data")
        .upload-zone#dropZone
          .upload-icon 📄
          .upload-text
            strong Click to select a CSV file
            span  or drag and drop here
          .upload-hint .csv only &nbsp;|&nbsp; max 10 MB &nbsp;|&nbsp; up to 5,000 rows
          input#csvFile(type="file" name="csvFile" accept=".csv" required)
        #filePreview.file-preview(style="display:none")
          .file-preview-icon 📄
          .file-preview-info
            .file-preview-name#fileName
            .file-preview-size#fileSize
          button.btn.btn-sm.btn-outline(type="button" onclick="clearFile()") ✕ Remove
        .form-actions
          button#importBtn.btn.btn-primary.btn-lg(type="submit" disabled)
            span 📥 Upload & Import

  //- CSV Format Guide
  .section-card
    .section-card-header
      h2 📋 CSV Format Guide
      a.btn.btn-outline.btn-sm(href="/import/template") 📥 Download Sample Template
    .section-card-body

      p.mb-12 Your CSV must include these column headers (order does not matter, column names are flexible):

      //- Required columns
      h4.guide-group-title Required Columns
      .csv-headers-grid
        .csv-col
          .csv-col-name location_id
          .csv-col-desc Numeric ID of the location. Must exist in the system.
          .csv-col-accepted Also accepted: location
        .csv-col
          .csv-col-name full_name
          .csv-col-desc Full name of the businessman (min 2 characters).
          .csv-col-accepted Also accepted: name, fullname
        .csv-col
          .csv-col-name gender
          .csv-col-desc Male or Female (case-insensitive).
          .csv-col-accepted Also accepted: sex
        .csv-col
          .csv-col-name nin
          .csv-col-desc Format: XXXXXXXX-XXXXX-XXXXX-XX (e.g. 19850312-12345-67890-01). Age is auto-calculated.
          .csv-col-accepted Also accepted: national_id
        .csv-col
          .csv-col-name mobile_number
          .csv-col-desc Phone number, minimum 9 digits.
          .csv-col-accepted Also accepted: mobile, phone, phone_number
        .csv-col
          .csv-col-name business_type
          .csv-col-desc Type of business (e.g. Retail Shop, Food Vendor).
          .csv-col-accepted Also accepted: business, type

      //- Optional columns
      h4.guide-group-title.mt-16 Optional Columns
      .csv-headers-grid
        .csv-col.csv-col-optional
          .csv-col-name block_name
          .csv-col-desc Name of the block/zone within the location. Matched by name (case-insensitive). If not found, record is still saved without a block.
          .csv-col-accepted Also accepted: block, zone, zone_name, block/zone
        .csv-col.csv-col-optional
          .csv-col-name cabin_number
          .csv-col-desc Cabin or stall number (e.g. C-101, A-22). Stored as-is.
          .csv-col-accepted Also accepted: cabin, cabin_no, stall, stall_number
        .csv-col.csv-col-optional
          .csv-col-name tin
          .csv-col-desc Tax Identification Number. Optional.
          .csv-col-accepted Also accepted: tin#, tax_id

      //- Example
      .csv-example.mt-16
        p.csv-example-title Example CSV:
        pre.csv-code.
          location_id,full_name,gender,nin,tin,mobile_number,business_type,block_name,cabin_number
          1,John Mwangi,Male,19850312-12345-67890-01,,0712345678,Retail Shop,Block A,C-101
          1,Amina Hassan,Female,19920605-98765-43210-02,123456789,0756789012,Food Vendor,Block A,C-102
          1,Peter Kimani,Male,19781120-11111-22222-03,,0745678901,Hardware Store,,

      //- Location & Block reference
      if locations && locations.length
        .location-reference.mt-16
          h4.guide-group-title 📍 Available Locations & Blocks (for reference)
          .loc-ref-grid
            each loc in locations
              .loc-ref-card
                .loc-ref-header
                  span.loc-ref-id ID: #{loc.id}
                  span.loc-ref-name= loc.locationName
                  span.loc-ref-ward= loc.ward
                if loc.blocks && loc.blocks.length
                  .loc-ref-blocks
                    each blk in loc.blocks
                      span.loc-ref-blk= blk.blockName
                else
                  p.loc-ref-no-blocks No blocks registered

block scripts
  script.
    const dropZone    = document.getElementById('dropZone');
    const fileInput   = document.getElementById('csvFile');
    const filePreview = document.getElementById('filePreview');
    const importBtn   = document.getElementById('importBtn');

    function showFile(file) {
      if (!file) return;
      document.getElementById('fileName').textContent = file.name;
      document.getElementById('fileSize').textContent = (file.size / 1024).toFixed(1) + ' KB';
      filePreview.style.display = 'flex';
      dropZone.style.display    = 'none';
      importBtn.disabled        = false;
    }
    function clearFile() {
      fileInput.value           = '';
      filePreview.style.display = 'none';
      dropZone.style.display    = 'flex';
      importBtn.disabled        = true;
    }

    fileInput.addEventListener('change', () => showFile(fileInput.files[0]));
    dropZone.addEventListener('click', () => fileInput.click());
    dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
    dropZone.addEventListener('drop', e => {
      e.preventDefault();
      dropZone.classList.remove('drag-over');
      const file = e.dataTransfer.files[0];
      if (file && file.name.endsWith('.csv')) {
        const dt = new DataTransfer(); dt.items.add(file); fileInput.files = dt.files;
        showFile(file);
      } else {
        alert('Please drop a .csv file.');
      }
    });

    document.getElementById('importForm').addEventListener('submit', function() {
      importBtn.disabled = true;
      importBtn.innerHTML = '<span class="spinner"></span> Importing...';
    });
