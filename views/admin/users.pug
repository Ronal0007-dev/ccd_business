extends ../layout

block content
  .page-header
    h1.page-title 👥 User Management
    a.btn.btn-primary(href="/users/add") ➕ Add New User
    a.btn.btn-outline(href="/dashboard") 🏠 Back Home

  if error && error.length
    .alert.alert-error ⚠️ #{error[0]}
  if success && success.length
    .alert.alert-success ✓ #{success[0]}

  .table-wrapper
    table.data-table
      thead
        tr
          th #
          th Full Name
          th Username
          th Email
          th Phone
          th Role
          th Status
          th Pwd
          th Actions
      tbody
        if users.length === 0
          tr
            td(colspan="9").empty-cell No users found.
        else
          each u, i in users
            tr
              td= i + 1
              td= u.fullName
              td
                code.username-code= u.username
              td= u.email || '—'
              td= u.phoneNumber
              td
                - const roleClass = u.role === 'admin' ? 'role-admin' : u.role === 'viewer' ? 'role-viewer' : 'role-entry'
                - const roleLabel = u.role === 'admin' ? '👑 Admin' : u.role === 'viewer' ? '👁 Viewer' : '✏️ Data Entry'
                span.role-badge(class=roleClass)= roleLabel
              td
                span.status-badge(class=u.isActive ? 'status-active' : 'status-inactive')
                  = u.isActive ? '● Active' : '● Inactive'
              td
                span.status-badge(class=u.mustChangePassword ? 'status-warn' : 'status-active')
                  = u.mustChangePassword ? '⚠ Pending' : '✓ Set'
              td
                .action-buttons
                  a.btn.btn-sm.btn-view(href="/users/" + u.id title='view') 👁
                  a.btn.btn-sm.btn-edit(href="/users/" + u.id + "/edit" title='edit') ✏️
                  form.inline-form-del(action="/users/" + u.id + "/reset-password" method="POST"
                    onsubmit="return confirm('Reset password for #{u.fullName} to their phone number?')")
                    button.btn.btn-sm.btn-warn(type="submit" title="Reset Password") 🔄
                  form.inline-form-del(action="/users/" + u.id + "?_method=DELETE" method="POST"
                    onsubmit="return confirm('Delete user #{u.fullName}?')")
                    input(type="hidden" name="_method" value="DELETE")
                    button.btn.btn-sm.btn-danger(type="submit" title="Delete") 🗑
