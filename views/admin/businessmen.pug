extends ../layout

block content
  - const f         = filters     || {}
  - const biz_list  = businessmen || []
  - const loc_list  = locations   || []
  - const blk_list  = filterBlocks || []
  - const pg        = pagination  || { page:1, totalPages:1, total:0, perPage:10, hasNext:false, hasPrev:false, startItem:0, endItem:0 }

  //- Build query string helper (preserves filters, sets page)
  - function pageUrl(p) { const q = new URLSearchParams(); if(f.search) q.set('search',f.search); if(f.gender) q.set('gender',f.gender); if(f.locationId) q.set('locationId',f.locationId); if(f.blockId) q.set('blockId',f.blockId); q.set('page',p); return '/businessmen?' + q.toString(); }

  .page-header
    h1.page-title 📋 Businessman Registry
    .page-actions
      a.btn.btn-outline(href="/dashboard") ← Dashboard
      if user.role !== 'viewer'
        a.btn.btn-primary(href="/businessmen/add") ➕ Add New
      if user.role === 'admin' || user.role === 'viewer'
        button.btn.btn-print(onclick="window.print()") 🖨 Print

  if error && error.length
    .alert.alert-error ⚠️ #{error[0]}
  if success && success.length
    .alert.alert-success ✓ #{success[0]}

  //- Filter Bar
  .filter-bar.no-print
    form#filterForm(action="/businessmen" method="GET")
      input(type="hidden" name="page" value="1")
      .filter-grid
        .filter-group
          label.filter-label 🔍 Search
          input#searchInput.filter-input(
            type="text" name="search" value=f.search
            placeholder="Name, NIN, mobile, cabin... (Enter to search)"
            autocomplete="off")
        .filter-group
          label.filter-label 👤 Gender
          select#genderFilter.filter-input(name="gender")
            option(value="" selected=!f.gender) All Genders
            option(value="Male"   selected=(f.gender==='Male'))   Male
            option(value="Female" selected=(f.gender==='Female')) Female
        .filter-group
          label.filter-label 📍 Location
          select#locationFilter.filter-input(name="locationId")
            option(value="" selected=!f.locationId) All Locations
            each loc in loc_list
              option(value=loc.id selected=(f.locationId==loc.id)) #{loc.locationName}
        .filter-group
          label.filter-label 🔲 Block/Zone
          select#blockFilter.filter-input(name="blockId" disabled=(!f.locationId))
            option(value="" selected=!f.blockId) All Blocks
            each blk in blk_list
              option(value=blk.id selected=(f.blockId==blk.id)) #{blk.blockName}
        .filter-group.filter-actions
          button.btn.btn-primary(type="submit") Apply
          if f.search || f.gender || f.locationId || f.blockId
            a.btn.btn-outline(href="/businessmen") ✕ Clear

  //- Results summary + page info
  .results-bar.no-print
    .results-summary
      if pg.total === 0
        span No records found
      else
        span Showing&nbsp;
        strong #{pg.startItem}–#{pg.endItem}
        span &nbsp;of&nbsp;
        strong #{pg.total}
        span &nbsp;
        if f.search || f.gender || f.locationId || f.blockId
          span result(s)
        else
          span total records
    if pg.totalPages > 1
      .page-size-info Page #{pg.page} of #{pg.totalPages}

  //- Table
  .table-wrapper
    table.data-table
      thead
        tr
          th #
          th Full Name
          th Gender
          th NIN
          th Age
          th Mobile
          th Business Type
          th Location
          th Block/Zone
          th Cabin
          th Registered By
          th.no-print Actions
      tbody
        if biz_list.length === 0
          tr
            td(colspan="12").empty-cell
              .empty-state-inline
                span.empty-icon-sm 🔍
                if f.search || f.gender || f.locationId || f.blockId
                  p No records match your search.
                  a.btn.btn-outline.btn-sm(href="/businessmen") Clear filters
                else
                  p No businessmen registered yet.
        else
          each biz, i in biz_list
            tr
              td= pg.startItem + i
              td= biz.fullName
              td
                span.gender-badge(class= biz.gender === 'Male' ? 'badge-male' : 'badge-female')= biz.gender
              td.nin-cell= biz.nin
              td= biz.age
              td= biz.mobileNumber
              td= biz.businessType
              td
                if biz.location
                  div= biz.location.locationName
                  small.text-muted= biz.location.ward
                else
                  span.text-muted —
              td= biz.block ? biz.block.blockName : '—'
              td= biz.cabinNumber || '—'
              td= biz.registrar ? biz.registrar.fullName : '—'
              td.no-print
                .action-buttons
                  a.btn.btn-sm.btn-view(href="/businessmen/" + biz.id) 👁
                  if user.role === 'admin'
                    a.btn.btn-sm.btn-edit(href="/businessmen/" + biz.id + "/edit") ✏️
                    form(action="/businessmen/" + biz.id + "?_method=DELETE" method="POST" style="display:inline"
                      onsubmit="return confirm('Delete this record?')")
                      input(type="hidden" name="_method" value="DELETE")
                      button.btn.btn-sm.btn-danger(type="submit") 🗑

  //- Pagination controls
  if pg.totalPages > 1
    .pagination.no-print
      //- Previous
      if pg.hasPrev
        a.page-btn(href=pageUrl(pg.page - 1)) ‹ Prev
      else
        span.page-btn.page-btn-disabled ‹ Prev

      //- Page number buttons (show window of 5 around current)
      - const start = Math.max(1, pg.page - 2)
      - const end   = Math.min(pg.totalPages, pg.page + 2)
      if start > 1
        a.page-btn(href=pageUrl(1)) 1
        if start > 2
          span.page-ellipsis …

      - for (let p = start; p <= end; p++)
        if p === pg.page
          span.page-btn.page-btn-active= p
        else
          a.page-btn(href=pageUrl(p))= p

      if end < pg.totalPages
        if end < pg.totalPages - 1
          span.page-ellipsis …
        a.page-btn(href=pageUrl(pg.totalPages))= pg.totalPages

      //- Next
      if pg.hasNext
        a.page-btn(href=pageUrl(pg.page + 1)) Next ›
      else
        span.page-btn.page-btn-disabled Next ›

      span.page-jump.no-print
        | &nbsp; Go to page:&nbsp;
        input#pageJumpInput(type="number" min="1" max=pg.totalPages value=pg.page)

block head
  style.
    @media print {
      .navbar, .page-actions, .no-print, .alert, .filter-bar, .results-bar,
      .pagination { display: none !important; }
      .table-wrapper { overflow: visible; box-shadow: none; border: none; }
      table { font-size: 10px; }
      th, td { padding: 4px 6px !important; }
    }

block scripts
  script.
    const TOTAL_PAGES = !{JSON.stringify(pg.totalPages)};

    // Search: submit on Enter only, reset to page 1
    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
      searchInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          document.querySelector('#filterForm input[name="page"]').value = 1;
          document.getElementById('filterForm').submit();
        }
      });
    }

    // Gender/Location dropdowns: submit on change, reset to page 1
    ['genderFilter', 'locationFilter'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.addEventListener('change', () => {
        document.querySelector('#filterForm input[name="page"]').value = 1;
        document.getElementById('filterForm').submit();
      });
    });

    // Location → cascade block dropdown fetch
    const locationFilter = document.getElementById('locationFilter');
    const blockFilter    = document.getElementById('blockFilter');
    if (locationFilter) {
      locationFilter.addEventListener('change', async function() {
        const locId = this.value;
        blockFilter.innerHTML = '<option value="">All Blocks</option>';
        blockFilter.disabled = true;
        if (locId) {
          try {
            const res    = await fetch('/locations/' + locId + '/blocks');
            const blocks = await res.json();
            blocks.forEach(b => {
              const opt = document.createElement('option');
              opt.value = b.id; opt.textContent = b.blockName;
              blockFilter.appendChild(opt);
            });
            blockFilter.disabled = blocks.length === 0;
          } catch(e) {}
        }
        document.querySelector('#filterForm input[name="page"]').value = 1;
        document.getElementById('filterForm').submit();
      });
    }

    // Page jump input
    const pageJumpInput = document.getElementById('pageJumpInput');
    if (pageJumpInput) {
      pageJumpInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
          const p = Math.max(1, Math.min(TOTAL_PAGES, parseInt(this.value) || 1));
          window.location.href = !{JSON.stringify('')} + (function(){
            const url = new URL(window.location.href);
            url.searchParams.set('page', p);
            return url.toString();
          })();
        }
      });
      pageJumpInput.addEventListener('change', function() {
        const p = Math.max(1, Math.min(TOTAL_PAGES, parseInt(this.value) || 1));
        const url = new URL(window.location.href);
        url.searchParams.set('page', p);
        window.location.href = url.toString();
      });
    }
