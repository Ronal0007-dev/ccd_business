extends ../layout

block content
  .page-header
    h1.page-title= isEdit ? '✏️ Edit User' : '➕ Add New User'
    a.btn.btn-outline(href="/users") ← Back to Users

  if error && error.length
    each e in error
      .alert.alert-error ⚠️ #{e}

  .section-card
    .section-card-header
      h2= isEdit ? 'Edit User Details' : 'Create New System User'
      if !isEdit
        p.card-subtitle Default password = phone number. User must change it on first login.
    .section-card-body
      - var formAction = isEdit ? '/users/' + userData.id + '?_method=PUT' : '/users'
      form(action=formAction method="POST")
        if isEdit
          input(type="hidden" name="_method" value="PUT")

        .form-grid
          .form-group
            label Full Name *
            input(type="text" name="fullName" value=userData.fullName || '' placeholder="e.g. John Mwangi" required autofocus)

          .form-group
            label Email Address
            input(type="email" name="email" value=userData.email || '' placeholder="user@example.com")

          .form-group
            label Phone Number *
            input#phoneInput(type="text" name="phoneNumber" value=userData.phoneNumber || '' placeholder="e.g. 0712345678" required)
            if !isEdit
              small.field-hint This will be the default password

          .form-group
            label Role *
            select(name="role" required)
              option(value="") — Select Role —
              option(value="admin"      selected=(userData.role === 'admin'))      👑 Admin
              option(value="data_entry" selected=(userData.role === 'data_entry')) ✏️ Data Entry
              option(value="viewer"     selected=(userData.role === 'viewer'))     👁 Viewer (Read-Only)

          if !isEdit
            .form-group
              label Default Password (Auto-set)
              input#defaultPwdDisplay(type="text" value="" placeholder="Auto-filled from phone number" disabled)

          if isEdit
            .form-group
              label Account Status
              select(name="isActive")
                option(value="1" selected=(userData.isActive))  Active
                option(value="0" selected=(!userData.isActive)) Inactive

          if isEdit
            .form-group
              label Username (Read-only)
              input(type="text" value=userData.username disabled)

        .role-description
          .role-desc-item
            span.role-icon 👑
            .role-desc-text
              strong Admin
              span — Full access: manage users, locations, blocks, businessmen, import, backups
          .role-desc-item
            span.role-icon ✏️
            .role-desc-text
              strong Data Entry
              span — Add businessmen; view all records; cannot manage locations, users or backups
          .role-desc-item
            span.role-icon 👁
            .role-desc-text
              strong Viewer
              span — View and print businessmen records only; cannot add or modify any data

        .form-actions
          button.btn.btn-primary.btn-lg(type="submit")
            = isEdit ? '💾 Save Changes' : '➕ Create User'
          a.btn.btn-outline(href="/users") Cancel

block scripts
  if !isEdit
    script.
      const phoneInput   = document.getElementById('phoneInput');
      const pwdDisplay   = document.getElementById('defaultPwdDisplay');
      phoneInput.addEventListener('input', function() { pwdDisplay.value = this.value; });
