extends ../layout

block content
  .page-header
    h1.page-title 🗄️ System Backups
    .page-actions
      form(action="/backups/run" method="POST")
        button.btn.btn-primary(type="submit"
          onclick="return confirm('Run a manual backup now?')") ▶ Run Backup Now
      a.btn.btn-outline(href="/dashboard") ← Back Home

  if error && error.length
    .alert.alert-error ⚠️ #{error[0]}
  if success && success.length
    .alert.alert-success ✓ #{success[0]}

  .section-card.mb-20
    .section-card-header
      h2 Backup Schedule
    .section-card-body
      .backup-schedule-info
        .bsi-item
          .bsi-icon ⏰
          .bsi-text
            strong Automatic Backup
            p Runs every 3 days at 02:00 AM
        .bsi-item
          .bsi-icon 📦
          .bsi-text
            strong What is backed up
            p All businessmen, locations and user accounts (excluding passwords)
        .bsi-item
          .bsi-icon 🗑️
          .bsi-text
            strong Retention Policy
            p Last 10 backups are kept. Older files are auto-deleted.

  h2.section-title 📦 Available Backups (#{backups.length})

  if backups.length === 0
    .empty-state
      .empty-icon 🗄️
      p No backups yet. Click "Run Backup Now" to create the first one.
  else
    .table-wrapper
      table.data-table
        thead
          tr
            th #
            th Filename
            th Businessmen
            th Locations
            th Users
            th Size
            th Created At
            th Actions
        tbody
          each bk, i in backups
            tr
              td= i + 1
              td
                code.username-code= bk.filename
              td.text-center= bk.counts.businessmen || '—'
              td.text-center= bk.counts.locations || '—'
              td.text-center= bk.counts.users || '—'
              td= bk.size
              td= new Date(bk.createdAt).toLocaleString('en-GB', {day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'})
              td
                .action-buttons
                  a.btn.btn-sm.btn-view(href="/backups/download/" + bk.filename) ⬇ Download
                  form(action="/backups/" + bk.filename + "?_method=DELETE" method="POST" style="display:inline"
                    onsubmit="return confirm('Delete backup ' + '#{bk.filename}' + '?')")
                    input(type="hidden" name="_method" value="DELETE")
                    button.btn.btn-sm.btn-danger(type="submit") 🗑
