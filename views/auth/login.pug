doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Login — Dodoma CC
    link(rel="stylesheet" href="/css/style.css")
  body.login-body
    .login-wrapper
      .login-card
        .login-header
          .login-logo
            img.login-logo-img(src="/img/logo.jpg" alt="City Council of Dodoma")
          h1 City Council of Dodoma
          p.login-subtitle  - City Traders Registry System -
        
        if error && error.length
          .alert.alert-error
            span ⚠️
            = error[0]
        if success && success.length
          .alert.alert-success
            span ✓
            = success[0]

        form.login-form(action="/auth/login" method="POST")
          .form-group
            label(for="username") Username
            input#username(type="text" name="username" placeholder="Enter username" required autofocus)
          .form-group
            label(for="password") Password
            input#password(type="password" name="password" placeholder="Enter password" required)
          button.btn.btn-primary.btn-full(type="submit") Sign In
        
        .login-footer
          p &copy; #{new Date().getFullYear()} Dodoma City Council. All rights reserved.
