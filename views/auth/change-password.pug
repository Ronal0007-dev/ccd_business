doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Change Password — CTRS
    link(rel="stylesheet" href="/css/style.css")
  body.login-body
    .login-wrapper
      .login-card
        .login-header
          .login-logo
            img.login-logo-img(src="/img/logo.jpg" alt="CCD")
          h1 BizRegistry
          if forced
            p.login-subtitle.text-warning ⚠️ You must change your password before continuing
          else
            p.login-subtitle Change Your Password

        if error && error.length
          each e in error
            .alert.alert-error
              span ⚠️ #{e}
        if success && success.length
          .alert.alert-success
            span ✓ #{success[0]}

        form.login-form(action="/auth/change-password" method="POST")
          .form-group
            label Current Password
            input(type="password" name="currentPassword" placeholder="Enter current password" required autofocus)
          .form-group
            label New Password
            input(type="password" name="newPassword" placeholder="At least 6 characters" required)
          .form-group
            label Confirm New Password
            input(type="password" name="confirmPassword" placeholder="Re-enter new password" required)
          button.btn.btn-primary.btn-full(type="submit") 🔒 Change Password
          if !forced
            .form-footer-link
              a(href="/dashboard") ← Back to Dashboard

        .login-footer
          p &copy; #{new Date().getFullYear()} City Council of Dodoma
